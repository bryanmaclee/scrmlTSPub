// 02b — Struct type used as a typed array.

<program>

${
  type Person:struct = { name: string, age: number }

  @people = [
    { name: "Ada",  age: 36 },
    { name: "Alan", age: 41 },
  ]
}

<ul>
  ${
    for (let p of @people) {
      lift <li>${p.name} (${p.age})</li>
    }
  }
</ul>

</program>
