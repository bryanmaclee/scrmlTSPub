// 03a — Full `< db>` block wrapping a minimal todo UI.

<program>

< db src="tasks.db" tables="tasks">

  ${
    @tasks = []

    server function loadTasks() {
      lift ?{`SELECT id, title FROM tasks ORDER BY id`}.all()
    }

    if (@tasks.length == 0) {
      @tasks = loadTasks()
    }
  }

  <div>
    <h1>Tasks</h1>
    <ul>
      ${
        for (let t of @tasks) {
          lift <li>${t.title}</li>
        }
      }
    </ul>
  </div>

</>

</program>
