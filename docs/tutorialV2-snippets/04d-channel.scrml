// 04d — WebSocket channel. <channel name="..."> opens a live connection
// shared between all connected clients. @shared vars propagate automatically.

<program>

${
  @draft = ""
}

<div>
  <h1>Live Room</h1>

  <channel name="room">
    ${
      @shared tick = 0
    }
  </>

  <p>Tick: ${@tick}</p>
  <input type="text" bind:value=@draft/>
</div>

</program>
