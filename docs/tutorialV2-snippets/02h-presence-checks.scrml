// 02h — Presence checks. `is not not`, `is some`, `not @var`. Always parenthesized.

<program>

${
  @user     = { name: "Ada" }
  @email    = "ada@example.com"
  @loggedIn = true
}

<div>
  <p if=(@user is not not)>User is present.</p>
  <p if=(@email is some)>Email is provided.</p>
  <p if=(not @loggedIn)>Please sign in.</p>
</div>

</program>
