// 01f — Scoped styles via #{} block. Class names are rewritten per-component.

<program>

<div class="card">
  <h1>Scoped</h1>
  <p>This card's styles only apply inside this program.</p>
</div>

#{
  .card {
    max-width: 360px;
    margin: 2rem auto;
    padding: 1.5rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-family: sans-serif;
  }
  h1 { color: #2563eb; }
}

</program>
