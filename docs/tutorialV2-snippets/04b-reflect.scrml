// 04b — reflect() for compile-time type introspection.

<program>

${
  type Token:struct = {
    id:     number,
    value:  string,
    expiry: number,
  }
}

<table>
  <thead><tr><th>Field</th><th>Type</th></tr></thead>
  <tbody>
    ^{
      const info = reflect(Token)
      for (const f of info.fields) {
        emit(`<tr><td>${f.name}</td><td>${f.type}</td></tr>`)
      }
    }
  </tbody>
</table>

</program>
