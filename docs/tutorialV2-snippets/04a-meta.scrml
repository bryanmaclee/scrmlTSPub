// 04a — Compile-time meta. ^{} runs at build; emit() splices markup into the AST.

<program>

${
  const colors = [
    { name: "blue",  hex: "#2563eb" },
    { name: "green", hex: "#16a34a" },
    { name: "red",   hex: "#dc2626" },
  ]
}

<div class="palette">
  ^{
    for (const c of colors) {
      emit(`<div class="chip" style="background:${c.hex}">${c.name}</div>`)
    }
  }
</div>

</program>
