// meta-style-gen.scrml
// Use ^{} with emit() to generate CSS-related markup from a design token config.
// Tests: emit() producing elements with inline styles and class attributes.

<program>

^{
    const colors = [
        { name: "primary", hex: "#3b82f6" },
        { name: "secondary", hex: "#10b981" },
        { name: "accent", hex: "#f59e0b" },
        { name: "danger", hex: "#ef4444" }
    ];
    const pad = "16px";

    emit("<div class=color-palette>\n  <h2>Design Tokens/\n");
    colors.forEach(function(c) { emit("  <div class=swatch-" + c.name + ">\n    <span>" + c.name + " " + c.hex + "/\n  </div>\n"); });
    emit("</div>\n");
}

</>
