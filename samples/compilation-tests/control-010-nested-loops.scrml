// Nested for loops. Tests: for inside for.

<div>
    ${
        let matrix = [[1, 2], [3, 4], [5, 6]]
        for (let row of matrix) {
            for (let cell of row) {
                let doubled = cell * 2
            }
        }
    }
    <p>Matrix processed</>
</div>
