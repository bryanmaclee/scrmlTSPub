// comp-012-pagination.scrml
// Pagination pattern. Tests: page navigation.

<div>
    ${
        @currentPage = 1
        let totalPages = 5
        function goToPage(page) {
            @currentPage = page
        }
    }
    <nav class="pagination">
        <button onclick=goToPage(1)>First</>
        <button>Previous</>
        <span>Page ${@currentPage}</>
        <button>Next</>
        <button onclick=goToPage(5)>Last</>
    </nav>
</div>
