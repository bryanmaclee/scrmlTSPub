// reactive-013-nested-markup.scrml
// Reactive variables in nested markup contexts. Tests: @ at various depths.

<div class="app">
    ${ @title = "My App" }
    <header>
        <h1>App Header</>
    </header>
    <main>
        ${ @content = "Welcome" }
        <p>Main content area</>
    </main>
</div>
