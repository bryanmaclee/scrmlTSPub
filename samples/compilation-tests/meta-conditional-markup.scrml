// meta-conditional-markup.scrml
// Use ^{} with emit() for conditional HTML generation at compile time.
// Tests: emit() with if/else logic producing different markup branches.

<program>

^{
    const env = "production";
    const featureDark = true;
    const featureAnalytics = true;
    const featureDebug = false;

    if (env == "production") {
        emit("<meta name=robots content=indexfollow />\n");
    } else {
        emit("<meta name=robots content=noindexnofollow />\n");
    }

    if (featureAnalytics) {
        emit("<div class=analytics data-src=analytics>\n</div>\n");
    }

    if (featureDebug) {
        emit("<div id=debug-panel>\n<p>Debug mode active/\n</div>\n");
    }

    const theme = featureDark ? "dark" : "light";
    emit("<div class=app-" + theme + ">\n  <h1>App/\n</div>\n");
}

</>
