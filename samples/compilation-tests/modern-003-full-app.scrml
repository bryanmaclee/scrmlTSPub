// modern-003-full-app.scrml
// Complete small app using multiple features. Tests: full feature set.

type Role:enum = { Admin, User, Guest }

< userBadge name(string) role(Role)>
    <span class="badge">
        ${name} (${ match role {
            .Admin :> "Admin"
            .User :> "User"
            .Guest :> "Guest"
        } })
    </>
</>

@users = []
@filter = "all"

${
    function addUser(name, role) {
        @users = [...@users, { name: name, role: role }]
    }
    function filteredUsers() {
        if (@filter == "all") return @users
        return @users
    }
}

<div class="app">
    <h1>User Manager</>
    <div class="controls">
        <button onclick=${() => addUser("Alice", .Admin)}>Add Admin</>
        <button onclick=${() => addUser("Bob", .User)}>Add User</>
    </>
    <div class="list">
        ${ for (let u of filteredUsers()) {
            lift <userBadge name=u.name role=u.role></>
        } }
    </>
</>

~{ "user app"
    test "starts empty" { assert @users.length == 0 }
}
