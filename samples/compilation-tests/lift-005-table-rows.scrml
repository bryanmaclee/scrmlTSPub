// lift-005-table-rows.scrml
// Lift generating table rows. Tests: lift with tr/td markup.

<table>
    <thead>
        <tr>
            <th>Name</>
            <th>Score</>
        </tr>
    </thead>
    <tbody>
        ${
            let students = ["Alice", "Bob", "Charlie"]
            for (let s of students) {
                lift <tr>
                    <td>${s}</>
                    <td>100</>
                </tr>
            }
        }
    </tbody>
</table>
