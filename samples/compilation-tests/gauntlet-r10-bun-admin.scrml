// gauntlet-r10-bun-admin.scrml
// Round 10: Product Admin Panel -- Heavy SQL, CRUD, categories JOIN, stock tracking
// Developer persona: Bun ecosystem developer who knows bun:sqlite inside-out
// Friction tracking: see companion REPORT section at bottom of file

// ========================================
// DATABASE SETUP
// ========================================
// FRICTION NOTE: No DDL bootstrap mechanism inside < db> blocks.
// In raw Bun I'd do: db.exec(`CREATE TABLE IF NOT EXISTS ...`)
// at module load. In scrml I have no place to put this outside
// a function. Workaround: schema must be pre-existing or we
// put CREATE TABLE in a server function called on mount.
// FRICTION: ?{} inside a bare expression at state-block level --
// unclear if this compiles. Using server function for DDL instead.

< db src="./products.db" protect="cost_price" tables="products, categories, stock_movements">

    // ========================================
    // REACTIVE STATE
    // ========================================
    @products = []
    @categories = []
    @selectedCategory = not
    @searchQuery = ""
    @editingProduct = not
    @showEditForm = false
    @showCreateForm = false
    @statusMessage = ""
    @page = 1
    @pageSize = 20

    // FRICTION NOTE: const @derived -- this is the scrml derived value syntax.
    // No TypeScript type annotation on the derived expression. In TS I'd write
    // `const lowStock: Product[] = ...` but there's no type annotation syntax here.
    // The compiler must infer the type from the SQL result shape -- which it can't
    // do yet because §14.8 schema-derived types are not connected to ?{} results.
    const @lowStockCount = @products.filter(p => p.stock_qty < p.low_stock_threshold).length

    // ========================================
    // SCHEMA BOOTSTRAP (server function called on mount)
    // ========================================
    ${
        server function initSchema() {
            ?{`CREATE TABLE IF NOT EXISTS categories (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT NOT NULL UNIQUE,
                slug TEXT NOT NULL UNIQUE,
                created_at TEXT DEFAULT (datetime('now'))
            )`}.run()

            ?{`CREATE TABLE IF NOT EXISTS products (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT NOT NULL,
                description TEXT,
                price_cents INTEGER NOT NULL DEFAULT 0,
                cost_price INTEGER NOT NULL DEFAULT 0,
                stock_qty INTEGER NOT NULL DEFAULT 0,
                low_stock_threshold INTEGER NOT NULL DEFAULT 10,
                category_id INTEGER REFERENCES categories(id),
                image_url TEXT,
                sku TEXT UNIQUE,
                active INTEGER NOT NULL DEFAULT 1,
                created_at TEXT DEFAULT (datetime('now')),
                updated_at TEXT DEFAULT (datetime('now'))
            )`}.run()

            // FRICTION NOTE: bun:sqlite has db.transaction() for atomicity.
            // There is NO transaction() in ?{}. These two CREATE TABLEs run
            // as separate statements. For DDL this is fine. For multi-row
            // INSERTs it is a real problem -- see createProduct below.

            ?{`CREATE TABLE IF NOT EXISTS stock_movements (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                product_id INTEGER NOT NULL REFERENCES products(id),
                delta INTEGER NOT NULL,
                reason TEXT,
                created_at TEXT DEFAULT (datetime('now'))
            )`}.run()

            // Seed a default category if empty
            ?{`INSERT OR IGNORE INTO categories (name, slug) VALUES ('Uncategorized', 'uncategorized')`}.run()
        }

        // Mount-time: init schema then load data
        initSchema()
        loadProducts()
        loadCategories()
    }

    // ========================================
    // DATA LOADING
    // ========================================
    ${
        server function loadProducts() {
            // FRICTION NOTE: This is a JOIN across products + categories.
            // The ?{} passthrough handles it fine as a static template.
            // BUT: I cannot dynamically compose the WHERE clause based on
            // @selectedCategory and @searchQuery. I must use the SQLite
            // null-coalescing pattern (§8.4) for optional filters.
            // In raw bun:sqlite I'd build the query string conditionally.
            // Here I must write one query that handles all filter combos.
            let rows = ?{`
                SELECT
                    p.id,
                    p.name,
                    p.description,
                    p.price_cents,
                    p.stock_qty,
                    p.low_stock_threshold,
                    p.image_url,
                    p.sku,
                    p.active,
                    p.created_at,
                    p.updated_at,
                    c.name AS category_name,
                    c.id AS category_id,
                    c.slug AS category_slug
                FROM products p
                LEFT JOIN categories c ON p.category_id = c.id
                WHERE
                    (${@searchQuery} IS NULL OR ${@searchQuery} = '' OR p.name LIKE '%' || ${@searchQuery} || '%')
                    AND (${@selectedCategory} IS NULL OR c.id = ${@selectedCategory})
                ORDER BY p.created_at DESC
                LIMIT ${@pageSize} OFFSET ${(@page - 1) * @pageSize}
            `}.all()
            @products = rows
        }

        // FRICTION NOTE: I want .prepare() here for repeated calls.
        // loadProducts() is called on every filter change. In bun:sqlite I'd do:
        //   const stmt = db.prepare("SELECT ...")
        //   stmt.all(params)
        // Reusing a PreparedStatement across calls avoids re-parsing.
        // The spec §8.3 lists .prepare() as a supported method but I have no
        // way to store the PreparedStatement in a reactive variable and reuse it.
        // Every loadProducts() call re-prepares. This is a performance gap.

        server function loadCategories() {
            let rows = ?{`SELECT id, name, slug FROM categories ORDER BY name ASC`}.all()
            @categories = rows
        }

        server function loadProductCount() {
            let row = ?{`
                SELECT COUNT(*) AS total FROM products p
                LEFT JOIN categories c ON p.category_id = c.id
                WHERE
                    (${@searchQuery} IS NULL OR ${@searchQuery} = '' OR p.name LIKE '%' || ${@searchQuery} || '%')
                    AND (${@selectedCategory} IS NULL OR c.id = ${@selectedCategory})
            `}.get()
            return row.total
        }
    }

    // ========================================
    // CRUD -- CREATE
    // ========================================
    ${
        server function createProduct(name, description, priceCents, costPrice, stockQty, lowStockThreshold, categoryId, imageUrl, sku) {
            // FRICTION NOTE: In bun:sqlite I'd use db.transaction() here:
            //   const insert = db.transaction((data) => {
            //     const product = db.prepare("INSERT INTO products ...").run(data)
            //     db.prepare("INSERT INTO stock_movements ...").run(product.lastInsertRowid, data.stockQty)
            //     return product.lastInsertRowid
            //   })
            //
            // In scrml ?{} there is NO transaction(). These are two separate
            // statements with no atomicity guarantee. If the second .run() fails,
            // the product exists but has no stock_movement record.
            // SEVERITY: HIGH -- data integrity hole.

            ?{`
                INSERT INTO products (name, description, price_cents, cost_price, stock_qty, low_stock_threshold, category_id, image_url, sku)
                VALUES (${name}, ${description}, ${priceCents}, ${costPrice}, ${stockQty}, ${lowStockThreshold}, ${categoryId}, ${imageUrl}, ${sku})
            `}.run()

            // FRICTION NOTE: I need the lastInsertRowid to link the stock_movement.
            // In bun:sqlite: const result = stmt.run(); result.lastInsertRowid
            // In scrml: ?{...}.run() -- does RunResult expose lastInsertRowid?
            // Spec §8.5 says "Return value of .run() should include changes and
            // lastInsertRowid" but §8.5 is marked TODO. Unknown if this compiles.
            // Workaround: query for the inserted row by SKU to get the ID.
            let newProduct = ?{`SELECT id FROM products WHERE sku = ${sku}`}.get()

            if (newProduct) {
                ?{`
                    INSERT INTO stock_movements (product_id, delta, reason)
                    VALUES (${newProduct.id}, ${stockQty}, 'Initial stock')
                `}.run()
            }

            @showCreateForm = false
            @statusMessage = "Product created successfully"
            loadProducts()
        }
    }

    // ========================================
    // CRUD -- UPDATE
    // ========================================
    ${
        server function updateProduct(id, name, description, priceCents, categoryId, imageUrl, sku, lowStockThreshold, active) {
            ?{`
                UPDATE products SET
                    name = ${name},
                    description = ${description},
                    price_cents = ${priceCents},
                    category_id = ${categoryId},
                    image_url = ${imageUrl},
                    sku = ${sku},
                    low_stock_threshold = ${lowStockThreshold},
                    active = ${active},
                    updated_at = datetime('now')
                WHERE id = ${id}
            `}.run()

            @showEditForm = false
            @editingProduct = not
            @statusMessage = "Product updated"
            loadProducts()
        }

        server function adjustStock(productId, delta, reason) {
            // FRICTION NOTE: Again, no transaction(). These should be atomic.
            // If UPDATE succeeds but INSERT fails, stock count is wrong.
            ?{`UPDATE products SET stock_qty = stock_qty + ${delta} WHERE id = ${productId}`}.run()
            ?{`INSERT INTO stock_movements (product_id, delta, reason) VALUES (${productId}, ${delta}, ${reason})`}.run()
            loadProducts()
            @statusMessage = "Stock adjusted"
        }
    }

    // ========================================
    // CRUD -- DELETE
    // ========================================
    ${
        server function deleteProduct(id) {
            // FRICTION NOTE: Cascade delete. In bun:sqlite with transaction():
            //   db.transaction(() => {
            //     db.prepare("DELETE FROM stock_movements WHERE product_id = ?").run(id)
            //     db.prepare("DELETE FROM products WHERE id = ?").run(id)
            //   })()
            // In scrml: two separate .run() calls. No atomicity.
            ?{`DELETE FROM stock_movements WHERE product_id = ${id}`}.run()
            ?{`DELETE FROM products WHERE id = ${id}`}.run()
            @statusMessage = "Product deleted"
            loadProducts()
        }
    }

    // ========================================
    // CATEGORY CRUD
    // ========================================
    ${
        server function createCategory(name, slug) {
            ?{`INSERT INTO categories (name, slug) VALUES (${name}, ${slug})`}.run()
            loadCategories()
            @statusMessage = "Category created"
        }

        server function deleteCategory(id) {
            // Reassign products to Uncategorized before deleting category
            ?{`UPDATE products SET category_id = 1 WHERE category_id = ${id}`}.run()
            ?{`DELETE FROM categories WHERE id = ${id}`}.run()
            loadCategories()
            loadProducts()
            @statusMessage = "Category deleted"
        }
    }

    // ========================================
    // EDIT HELPERS
    // ========================================
    ${
        function startEdit(product) {
            @editingProduct = product
            @showEditForm = true
            @showCreateForm = false
        }

        function cancelEdit() {
            @editingProduct = not
            @showEditForm = false
        }

        function startCreate() {
            @showCreateForm = true
            @showEditForm = false
            @editingProduct = not
        }

        function cancelCreate() {
            @showCreateForm = false
        }

        // FRICTION NOTE: Currency formatting. In Bun / Node I'd use:
        //   Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(cents / 100)
        // In scrml there's no built-in number formatting. I can call Intl.NumberFormat
        // inside a ${ } logic context -- it's JavaScript passthrough. But can I call
        // it inline inside markup interpolation ${formatPrice(product.price_cents)}?
        // Verified pattern: define it as a helper function in ${}, call in markup.
        function formatPrice(cents) {
            return "$" + (cents / 100).toFixed(2)
        }

        function formatDate(isoStr) {
            if (!isoStr) { return "N/A" }
            return isoStr.substring(0, 10)
        }

        // FRICTION NOTE: When search/filter changes, I need to reload.
        // In bun:sqlite I'd just call db.prepare().all(). In scrml I need to
        // call a server function, which is an async round-trip to the server.
        // Every filter keypress triggers a server call. There's no local
        // re-filtering of a cached result set -- the SQL runs server-side.
        // This is correct architecture but the latency story for search-as-you-type
        // is rough without debouncing, and scrml has no debounce primitive.
        function handleSearchInput(event) {
            @searchQuery = event.target.value
            @page = 1
            loadProducts()
        }

        function handleCategoryFilter(categoryId) {
            @selectedCategory = categoryId
            @page = 1
            loadProducts()
        }

        function nextPage() {
            @page = @page + 1
            loadProducts()
        }

        function prevPage() {
            if (@page > 1) {
                @page = @page - 1
                loadProducts()
            }
        }
    }

    // ========================================
    // MARKUP -- ADMIN SHELL
    // ========================================
    <div class="admin-panel">

        // Header
        <div class="admin-header">
            <h1>Product Admin</>
            <div class="header-actions">
                <span class="badge-alert" if=@lowStockCount>
                    Low stock: ${@lowStockCount} items
                </>
                <button onclick=startCreate()>+ New Product</>
            </>
        </>

        // Status message
        <div class="status-message" if=@statusMessage>
            <p>${@statusMessage}</>
        </>

        // --------------------------------------------------------
        // FILTER BAR
        // --------------------------------------------------------
        <div class="filter-bar">
            <input
                type="text"
                placeholder="Search products..."
                value=@searchQuery
                oninput=handleSearchInput()>

            // FRICTION NOTE: No bind:value here because oninput is manual.
            // bind:value and oninput cannot coexist (E-ATTR-012).
            // Pattern: manual oninput with event.target.value is the only option
            // when the handler also needs to trigger a server call.

            <select onchange=handleCategoryFilter()>
                <option value="">All categories</>
                ${
                    for (let cat of @categories) {
                        lift <option value="${cat.id}">${cat.name}</>
                    }
                }
            </>
        </>

        // --------------------------------------------------------
        // CREATE FORM
        // --------------------------------------------------------
        <div class="create-form" if=@showCreateForm>
            <h2>Create Product</>

            // FRICTION NOTE: No form state management. I need @-prefixed reactive
            // vars for each field in the form. In React I'd use useState or useReducer.
            // In scrml I declare individual @vars. This is verbose for 9-field forms.
            // There's no struct-as-form-state idiom. I'd want something like:
            //   @newProduct = { name: "", price_cents: 0, ... }
            // where @newProduct.name binds to an input. Object reactive state with
            // field-level reactivity is unspecified.

            @newName = ""
            @newDescription = ""
            @newPriceCents = 0
            @newCostPrice = 0
            @newStockQty = 0
            @newLowStockThreshold = 10
            @newCategoryId = 1
            @newImageUrl = ""
            @newSku = ""

            <form onsubmit=createProduct(@newName, @newDescription, @newPriceCents, @newCostPrice, @newStockQty, @newLowStockThreshold, @newCategoryId, @newImageUrl, @newSku)>
                <label>Product Name
                    <input type="text" bind:value=@newName required>
                </>
                <label>SKU
                    <input type="text" bind:value=@newSku>
                </>
                <label>Description
                    <textarea bind:value=@newDescription></>
                </>
                <label>Price (cents)
                    <input type="number" bind:value=@newPriceCents>
                    // FRICTION NOTE: bind:value always returns a string from the DOM.
                    // bind:valueAsNumber is listed in familiarize.md as an open issue (M-3).
                    // @newPriceCents will be "500" not 500. SQL INSERT will type-coerce in
                    // SQLite (because SQLite is dynamically typed) but this is a latent bug.
                </>
                <label>Cost Price (cents, internal only)
                    // FRICTION NOTE: cost_price is in protect="cost_price" on the db state block.
                    // protect= prevents it from being returned to the client in SELECT queries.
                    // But I can still INSERT it from a server function -- that's correct.
                    // The protect= boundary is client-facing SELECTs only.
                    <input type="number" bind:value=@newCostPrice>
                </>
                <label>Initial Stock Qty
                    <input type="number" bind:value=@newStockQty>
                </>
                <label>Low Stock Threshold
                    <input type="number" bind:value=@newLowStockThreshold>
                </>
                <label>Category
                    <select bind:value=@newCategoryId>
                        ${
                            for (let cat of @categories) {
                                lift <option value="${cat.id}">${cat.name}</>
                            }
                        }
                    </>
                </>
                <label>Image URL
                    // FRICTION NOTE: Image upload is not expressible in scrml.
                    // File/Blob/ReadableStream have no type in the scrml type system.
                    // This field is a URL-only text input. File upload requires a
                    // completely separate mechanism (form multipart POST via raw HTML
                    // or a Bun.serve() endpoint written outside scrml).
                    <input type="text" bind:value=@newImageUrl placeholder="https://...">
                </>
                <div class="form-actions">
                    <button type="submit">Create Product</>
                    <button type="button" onclick=cancelCreate()>Cancel</>
                </>
            </>
        </>

        // --------------------------------------------------------
        // EDIT FORM
        // --------------------------------------------------------
        <div class="edit-form" if=@showEditForm>
            <h2>Edit: ${@editingProduct.name}</>

            // FRICTION NOTE: Prepopulating form fields from @editingProduct.
            // In React I'd seed useState from the selected row.
            // In scrml: I use @editingProduct directly as the source.
            // bind:value=@editingProduct.name -- does scrml support nested
            // reactive property binding? Spec §5.4 says bind: requires @var.
            // @editingProduct is a @var, @editingProduct.name is a property access.
            // This is a grey area. Using explicit @edit* vars to be safe.

            @editName = @editingProduct.name
            @editDescription = @editingProduct.description
            @editPriceCents = @editingProduct.price_cents
            @editCategoryId = @editingProduct.category_id
            @editImageUrl = @editingProduct.image_url
            @editSku = @editingProduct.sku
            @editLowStockThreshold = @editingProduct.low_stock_threshold
            @editActive = @editingProduct.active

            <form onsubmit=updateProduct(@editingProduct.id, @editName, @editDescription, @editPriceCents, @editCategoryId, @editImageUrl, @editSku, @editLowStockThreshold, @editActive)>
                <label>Name
                    <input type="text" bind:value=@editName>
                </>
                <label>SKU
                    <input type="text" bind:value=@editSku>
                </>
                <label>Description
                    <textarea bind:value=@editDescription></>
                </>
                <label>Price (cents)
                    <input type="number" bind:value=@editPriceCents>
                </>
                <label>Low Stock Threshold
                    <input type="number" bind:value=@editLowStockThreshold>
                </>
                <label>Category
                    <select bind:value=@editCategoryId>
                        ${
                            for (let cat of @categories) {
                                lift <option value="${cat.id}">${cat.name}</>
                            }
                        }
                    </>
                </>
                <label>Image URL
                    <input type="text" bind:value=@editImageUrl>
                </>
                <label>Active
                    <input type="checkbox" bind:checked=@editActive>
                </>
                <div class="form-actions">
                    <button type="submit">Save Changes</>
                    <button type="button" onclick=cancelEdit()>Cancel</>
                </>
            </>
        </>

        // --------------------------------------------------------
        // LOW STOCK ALERTS
        // --------------------------------------------------------
        <div class="low-stock-alerts" if=@lowStockCount>
            <h3>Low Stock Alerts (${@lowStockCount})</>
            <ul>
                ${
                    for (let p of @products.filter(p => p.stock_qty < p.low_stock_threshold)) {
                        lift <li class="alert-row">
                            <span>${p.name}</>
                            <span class="stock-count">${p.stock_qty} remaining</>
                            <span class="threshold">(threshold: ${p.low_stock_threshold})</>
                        </>
                    }
                }
            </>
        </>

        // --------------------------------------------------------
        // PRODUCT TABLE
        // --------------------------------------------------------
        <div class="products-table-container">
            <table class="products-table">
                <thead>
                    <tr>
                        <th>Image</>
                        <th>SKU</>
                        <th>Name</>
                        <th>Category</>
                        <th>Price</>
                        <th>Stock</>
                        <th>Status</>
                        <th>Created</>
                        <th>Actions</>
                    </>
                </>
                <tbody>
                    ${
                        for (let product of @products) {
                            lift <tr class="${product.active ? 'active-row' : 'inactive-row'}">
                                <td>
                                    <img src="${product.image_url || '/placeholder.png'}" alt="${product.name}" class="product-thumb"/>
                                </>
                                <td class="sku">${product.sku}</>
                                <td class="product-name">
                                    <strong>${product.name}</>
                                    <small>${product.description}</>
                                </>
                                <td>${product.category_name || 'Uncategorized'}</>
                                <td class="price">${formatPrice(product.price_cents)}</>
                                <td class="${product.stock_qty < product.low_stock_threshold ? 'low-stock' : 'ok-stock'}">
                                    ${product.stock_qty}
                                    // FRICTION NOTE: Inline conditional class on td -- the
                                    // class="${expr ? 'a' : 'b'}" pattern works because it's
                                    // inside a ${ } lift context. But the syntax is a quoted
                                    // string with a template expression -- this means scrml is
                                    // treating class= as a dynamic string attribute here, not
                                    // as static. The spec §5.5 CSS class binding is TODO.
                                    // This works but feels unintentional -- we're abusing the
                                    // quoted string attribute form.
                                </>
                                <td>${product.active ? 'Active' : 'Inactive'}</>
                                <td>${formatDate(product.created_at)}</>
                                <td class="actions">
                                    <button onclick=startEdit(product)>Edit</>
                                    <button onclick=deleteProduct(product.id)>Delete</>
                                </>
                            </>
                        }
                    }
                </>
            </>
        </>

        // FRICTION NOTE: The nested lift inside the for loop generates a full
        // <tr> with many children. This is a deeply nested lift that spans
        // many lines. The compiler handles it because </tr> is an explicit
        // close tag, not a bare slash. The explicit closer form is necessary
        // here -- bare slash would be ambiguous.

        // --------------------------------------------------------
        // PAGINATION
        // --------------------------------------------------------
        <div class="pagination">
            <button onclick=prevPage() if=@page>Previous</>
            <span>Page ${@page}</>
            <button onclick=nextPage()>Next</>
        </>

        // --------------------------------------------------------
        // STOCK ADJUSTMENT PANEL
        // --------------------------------------------------------
        @adjustProductId = not
        @adjustDelta = 0
        @adjustReason = ""
        @showStockPanel = false

        <div class="stock-panel" if=@showStockPanel>
            <h3>Adjust Stock</>
            <label>Product ID
                <input type="number" bind:value=@adjustProductId>
            </>
            <label>Delta (+ to add, - to remove)
                <input type="number" bind:value=@adjustDelta>
            </>
            <label>Reason
                <input type="text" bind:value=@adjustReason>
            </>
            <button onclick=adjustStock(@adjustProductId, @adjustDelta, @adjustReason)>Apply</>
            <button onclick=${@showStockPanel = false}>Close</>
        </>
        <button onclick=${@showStockPanel = !@showStockPanel}>Stock Adjustments</>

        // --------------------------------------------------------
        // CATEGORY MANAGEMENT
        // --------------------------------------------------------
        @showCategoryPanel = false
        @newCategoryName = ""
        @newCategorySlug = ""

        <div class="category-panel" if=@showCategoryPanel>
            <h3>Manage Categories</>
            <ul>
                ${
                    for (let cat of @categories) {
                        lift <li>
                            <span>${cat.name}</>
                            <button onclick=deleteCategory(cat.id)>Delete</>
                        </>
                    }
                }
            </>
            <div class="add-category">
                <input type="text" bind:value=@newCategoryName placeholder="Category name">
                <input type="text" bind:value=@newCategorySlug placeholder="slug">
                <button onclick=createCategory(@newCategoryName, @newCategorySlug)>Add Category</>
            </>
        </>
        <button onclick=${@showCategoryPanel = !@showCategoryPanel}>Categories</>

    </>

</>

// ========================================
// SCRML R10 FRICTION REPORT
// ========================================
// (See companion report delivered to user -- comments below are
//  inline friction notes captured during authoring)
//
// CONFIRMED WORKING:
// - ?{`SELECT ... JOIN ...`}.all() -- multi-table JOIN in static template
// - ?{`SELECT ...`}.get() -- single row fetch
// - ?{`INSERT INTO ...`}.run() -- write operations
// - ?{`UPDATE ...`}.run() -- with multiple ${param} bound params
// - ?{`DELETE FROM ...`}.run() -- with bound param
// - const @derived for low stock count -- derived reactive pattern
// - < db protect="cost_price"> -- column protection at state block level
// - bind:value, bind:checked on form inputs
// - for + lift generating <option> elements inside <select>
// - Nested lift with explicit </tr> closer for table rows
// - @statusMessage if= conditional display
//
// FRICTION ITEMS (summary -- full report below):
// 1. No transaction() in ?{} -- multi-statement atomicity gap [BLOCKER]
// 2. No .prepare() reuse across calls -- performance gap [HIGH]
// 3. .run() return value (lastInsertRowid) -- spec is TODO [HIGH]
// 4. No DDL bootstrap mechanism at state-block level [HIGH]
// 5. bind:value always returns string (M-3, bind:valueAsNumber) [HIGH]
// 6. No debounce primitive for search-as-you-type [MEDIUM]
// 7. No image/file upload type in scrml type system [MEDIUM]
// 8. No struct-as-form-state -- 9 individual @vars for one form [MEDIUM]
// 9. bind:value on nested property (@obj.field) unspecified [MEDIUM]
// 10. §5.5 dynamic class binding is TODO -- using string ternary hack [LOW]
